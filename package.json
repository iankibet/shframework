{
  "name": "@iankibetsh/shframework",
  "version": "6.0.1",
  "description": "Vue Bootstrap 5 component library for handling laravel backend, built on @iankibetsh/sh-core",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iankibet/shframework.git"
  },
  "type": "module",
  "main": "dist/shframework.cjs.js",
  "module": "dist/shframework.es.js",
  "exports": {
    ".": {
      "import": "./dist/shframework.es.js",
      "require": "./dist/shframework.cjs.js"
    },
    "./style.css": "./dist/shframework.css",
    "./dist/dist/library.mjs.css": "./dist/shframework.css"
  },
  "files": [
    "dist/*"
  ],
  "scripts": {
    "test": "echo \"Error: no test specifieds\" && exit 1",
    "build": "vite build -c vite.lib.config.js",
    "docs:dev": "vuepress dev docs",
    "docs:build": "vuepress build docs",
    "dev": "vite",
    "serve": "vite"
  },
  "bin": {
    "sh-copy-defaults": "./src/lib/cmds/cli.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "bootstrap": "^5.3",
    "bootstrap-icons": "^1.10",
    "pinia": "^3",
    "vue": "^3.5",
    "vue-router": "^4 || ^5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6",
    "@vue/test-utils": "^2.2.4",
    "@vuepress/bundler-vite": "^2.0.0-rc.8",
    "@vuepress/theme-default": "^2.0.0-rc.17",
    "eslint": "^8.22.0",
    "eslint-plugin-vue": "^9.3.0",
    "jsdom": "^20.0.3",
    "lru-cache": "^10.2.0",
    "sass": "^1.56.2",
    "vite": "^8",
    "vitest": "^0.25.3",
    "vuepress": "^2.0.0-rc.8"
  },
  "dependencies": {
    "@iankibetsh/sh-core": "^1.0.0",
    "luxon": "^3.7.2",
    "nprogress": "^0.2.0"
  }
}
